# Server
PORT=8000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=60m

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# ElevenLabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# D-ID
DID_API_KEY=your-did-api-key
DID_API_URL=https://api.d-id.com

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173











-----------------------------------------------------------------------------------------------------------------------------------












# =============================================================
#  AI Interview Platform — Node.js Backend Environment Variables
#  Copy this file to .env and fill in ALL values before running
# =============================================================

# ── SERVER ────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development
# Options: development | production

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================
#  SUPABASE
#  Get from: https://supabase.com/dashboard → your project
#            → Settings → API
# =============================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key
# ⚠️  NEVER expose SERVICE_ROLE_KEY on the frontend — backend only!

# =============================================================
#  JWT (JSON Web Tokens)
#  Generate a strong secret:
#  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================
JWT_SECRET=replace-with-64-char-random-hex-string-generated-above
JWT_EXPIRES_IN=60m
# Options: 15m | 30m | 60m | 2h | 24h

# =============================================================
#  OPENAI — Whisper STT + GPT-4o Evaluation
#  Get from: https://platform.openai.com/api-keys
# =============================================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model used for transcription (do not change unless upgrading)
OPENAI_WHISPER_MODEL=whisper-1
# Model used for answer evaluation
OPENAI_EVAL_MODEL=gpt-4o

# =============================================================
#  ELEVENLABS — Text-to-Speech (Avatar Voice)
#  Get API key : https://elevenlabs.io → Profile → API Keys
#  Get voice ID: https://elevenlabs.io → Voices → click voice → copy ID
#  Free plan: 10,000 chars/month
#  Recommended voices for professional interviewer:
#    - Rachel  : 21m00Tcm4TlvDq8ikWAM
#    - Adam    : pNInz6obpgDQGcFmaJgB
#    - Bella   : EXAVITQu4vr4xnSDxMaL (default)
# =============================================================
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Voice stability (0.0 - 1.0) — higher = more consistent
ELEVENLABS_STABILITY=0.5
# Voice similarity boost (0.0 - 1.0)
ELEVENLABS_SIMILARITY_BOOST=0.8
# Voice style (0.0 - 1.0) — expressiveness
ELEVENLABS_STYLE=0.3

# =============================================================
#  D-ID — AI Talking Avatar Video Generation
#  Get from: https://studio.d-id.com → Settings → API
#  API key format: Basic base64(email:api_key) — copy from dashboard
#  Get presenter IDs: https://docs.d-id.com/reference/get-presenters
#  Free plan: 20 credits (~20 videos)
#  Recommended presenters:
#    - Amy (formal) : amy-Aq6OmGZnMt
#    - Noelle       : Noelle-en-US
#    - Jack         : jack-AUI-9DpX
# =============================================================
DID_API_KEY=Basic xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DID_API_URL=https://api.d-id.com
# Default presenter used when no avatar is configured per course
DID_DEFAULT_PRESENTER_ID=amy-Aq6OmGZnMt
# Driver controls avatar animation style
DID_DEFAULT_DRIVER_URL=bank://lively
# How long to poll for D-ID video (seconds)
DID_POLL_TIMEOUT_SECONDS=60

# =============================================================
#  SUPABASE STORAGE (for audio file uploads)
#  Bucket names — create these in Supabase Storage dashboard
# =============================================================
SUPABASE_STORAGE_BUCKET_AUDIO=interview-audio
SUPABASE_STORAGE_BUCKET_IMAGES=course-images
SUPABASE_STORAGE_BUCKET_BACKGROUNDS=interview-backgrounds
# Max audio file size in MB
MAX_AUDIO_SIZE_MB=25

# =============================================================
#  OPTIONAL: Email notifications (future feature)
#  Uncomment and fill if you want interview reminder emails
# =============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@aiinterview.com
